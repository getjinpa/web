<script>
  // ======================================
  // Jinpa Setup Wizard - Client-Side Logic
  // ======================================

  interface TemplateInfo {
    name: string;
    slug: string;
    repo: string;
    description: string;
    thumbnail: string;
    preview: string;
    category: string;
    features: string[];
  }

  interface TemplatesData {
    templates: TemplateInfo[];
  }

  // --- OAuth Config ---
  const GITHUB_CLIENT_ID = 'Ov23liXz8yefnJ84nHTM';
  const WORKER_CALLBACK = 'https://jinpa-auth.buddhistapps.workers.dev/callback';

  // --- State ---
  let currentStep = 1;
  let githubToken = '';
  let githubUsername = '';
  let selectedTemplate: TemplateInfo | null = null;

  // --- DOM References ---
  const connectBtn = document.getElementById('connect-github-btn') as HTMLButtonElement;
  const authError = document.getElementById('auth-error') as HTMLDivElement;
  const authErrorMsg = document.getElementById('auth-error-message') as HTMLSpanElement;
  const authSuccess = document.getElementById('auth-success') as HTMLDivElement;
  const usernameDisplay = document.getElementById('github-username') as HTMLElement;

  const siteNameInput = document.getElementById('site-name') as HTMLInputElement;
  const siteDescInput = document.getElementById('site-description') as HTMLInputElement;
  const repoNameInput = document.getElementById('repo-name') as HTMLInputElement;
  const previewUsername = document.getElementById('preview-username') as HTMLElement;
  const previewRepo = document.getElementById('preview-repo') as HTMLElement;
  const configForm = document.getElementById('config-form') as HTMLFormElement;
  const backToStep1 = document.getElementById('back-to-step-1') as HTMLButtonElement;
  const selectedTemplateName = document.getElementById('selected-template-name') as HTMLElement;

  const creatingProgress = document.getElementById('creating-progress') as HTMLDivElement;
  const creatingStatus = document.getElementById('creating-status') as HTMLElement;
  const creatingError = document.getElementById('creating-error') as HTMLDivElement;
  const creatingErrorMsg = document.getElementById('creating-error-message') as HTMLSpanElement;

  const successSiteUrl = document.getElementById('success-site-url') as HTMLAnchorElement;
  const visitSiteBtn = document.getElementById('visit-site-btn') as HTMLAnchorElement;
  const adminPanelBtn = document.getElementById('admin-panel-btn') as HTMLAnchorElement;
  const successActions = document.getElementById('success-actions') as HTMLDivElement;
  const adminSetupSection = document.getElementById('admin-setup-section') as HTMLDivElement;

  // Admin setup elements
  const adminTokenInput = document.getElementById('admin-token') as HTMLInputElement;
  const adminPw1 = document.getElementById('admin-password') as HTMLInputElement;
  const adminPw2 = document.getElementById('admin-password2') as HTMLInputElement;
  const setupAdminBtn = document.getElementById('setup-admin-btn') as HTMLButtonElement;
  const skipAdminBtn = document.getElementById('skip-admin-setup') as HTMLButtonElement;
  const adminSetupError = document.getElementById('admin-setup-error') as HTMLDivElement;
  const adminSetupErrorMsg = document.getElementById('admin-setup-error-msg') as HTMLSpanElement;
  const createTokenLink = document.getElementById('create-admin-token-link') as HTMLAnchorElement;
  const adminRepoNameDisplay = document.getElementById('admin-repo-name-display') as HTMLSpanElement;

  // Track created repo info
  let createdRepoName = '';
  let createdSiteUrl = '';

  // --- Initialize ---
  async function init() {
    // Get template from URL params
    const params = new URLSearchParams(window.location.search);
    const templateSlug = params.get('template') || 'starter-blog';

    try {
      const response = await fetch('/templates.json');
      const data: TemplatesData = await response.json();
      selectedTemplate = data.templates.find(t => t.slug === templateSlug) || data.templates[0];

      if (selectedTemplate && selectedTemplateName) {
        selectedTemplateName.textContent = selectedTemplate.name;
      }
    } catch (e) {
      // Fallback template
      selectedTemplate = {
        name: 'Starter Blog',
        slug: 'starter-blog',
        repo: 'getjinpa/jinpa-starter',
        description: 'A clean, minimal blog',
        thumbnail: '/thumbnails/starter-blog.jpg',
        preview: 'https://getjinpa.github.io/jinpa-starter/',
        category: 'blog',
        features: ['darkMode', 'search', 'rss'],
      };
    }

    // Handle returning from GitHub OAuth
    await handleOAuthCallback();
  }

  init();

  // --- Step Navigation ---
  function goToStep(step: number) {
    currentStep = step;

    // Update step indicators
    document.querySelectorAll('.step').forEach(el => {
      const stepNum = parseInt(el.getAttribute('data-step') || '0');
      el.classList.remove('active', 'completed');
      if (stepNum === currentStep) el.classList.add('active');
      if (stepNum < currentStep) el.classList.add('completed');
    });

    document.querySelectorAll('.step-connector').forEach(el => {
      const connNum = parseInt(el.getAttribute('data-connector') || '0');
      el.classList.toggle('completed', connNum < currentStep);
    });

    // Show/hide step panels
    for (let i = 1; i <= 4; i++) {
      const panel = document.getElementById(`step-${i}`);
      if (panel) panel.hidden = i !== currentStep;
    }
  }

  // --- Step 1: GitHub OAuth ---
  connectBtn?.addEventListener('click', () => {
    const state = crypto.randomUUID();
    sessionStorage.setItem('oauth_state', state);
    const authUrl = new URL('https://github.com/login/oauth/authorize');
    authUrl.searchParams.set('client_id', GITHUB_CLIENT_ID);
    authUrl.searchParams.set('scope', 'repo,workflow');
    authUrl.searchParams.set('redirect_uri', WORKER_CALLBACK);
    authUrl.searchParams.set('state', state);
    window.location.href = authUrl.toString();
  });

  async function handleOAuthCallback() {
    // Check for OAuth error passed as query param by the Worker
    const params = new URLSearchParams(window.location.search);
    const urlError = params.get('error');
    if (urlError) {
      const msg = decodeURIComponent(urlError).replace(/_/g, ' ');
      showAuthError(`GitHub login failed: ${msg}`);
      // Clean the error param from URL
      const cleanSearch = window.location.search.replace(/[?&]error=[^&]*/, '').replace(/^\?$/, '');
      history.replaceState(null, '', window.location.pathname + cleanSearch);
      return;
    }

    // Check URL hash for token returned by the Worker
    const hash = window.location.hash;
    if (!hash.startsWith('#token=')) return;

    const hashParams = new URLSearchParams(hash.slice(1));
    const token = hashParams.get('token');
    const returnedState = hashParams.get('state');

    if (!token) return;

    // Validate CSRF state
    const savedState = sessionStorage.getItem('oauth_state');
    if (savedState && returnedState !== savedState) {
      showAuthError('Security check failed. Please try logging in again.');
      history.replaceState(null, '', window.location.pathname + window.location.search);
      return;
    }
    sessionStorage.removeItem('oauth_state');

    // Remove token from URL immediately (never in browser history)
    history.replaceState(null, '', window.location.pathname + window.location.search);

    // Show loading state
    if (connectBtn) {
      connectBtn.disabled = true;
      connectBtn.innerHTML = '<div class="spinner" style="width:1rem;height:1rem;border-width:2px;"></div> Connecting...';
    }
    hideAuthError();

    try {
      const res = await fetch('https://api.github.com/user', {
        headers: {
          Authorization: `token ${token}`,
          Accept: 'application/vnd.github.v3+json',
        },
      });

      if (!res.ok) throw new Error('GitHub login failed. Please try again.');

      const user = await res.json();
      githubToken = token;
      githubUsername = user.login;

      if (authSuccess) {
        authSuccess.hidden = false;
        if (usernameDisplay) usernameDisplay.textContent = githubUsername;
      }
      if (previewUsername) previewUsername.textContent = githubUsername;

      setTimeout(() => goToStep(2), 800);
    } catch (err: any) {
      showAuthError(err.message || 'Failed to connect to GitHub. Please try again.');
      if (connectBtn) {
        connectBtn.disabled = false;
        connectBtn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg> Login with GitHub`;
      }
    }
  }

  function showAuthError(msg: string) {
    if (authError && authErrorMsg) {
      authError.hidden = false;
      authErrorMsg.textContent = msg;
    }
  }

  function hideAuthError() {
    if (authError) authError.hidden = true;
  }

  // --- Step 2: Configure ---
  siteNameInput?.addEventListener('input', () => {
    const name = siteNameInput.value.trim();
    const slug = name
      .toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .substring(0, 60);

    if (repoNameInput && !repoNameInput.dataset.manual) {
      repoNameInput.value = slug;
      if (previewRepo) previewRepo.textContent = slug || 'repo-name';
    }
  });

  repoNameInput?.addEventListener('input', () => {
    repoNameInput.dataset.manual = 'true';
    if (previewRepo) previewRepo.textContent = repoNameInput.value || 'repo-name';
  });

  backToStep1?.addEventListener('click', () => goToStep(1));

  configForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    await createSite();
  });

  // --- Step 3: Create Site ---
  async function createSite() {
    const siteName = siteNameInput?.value.trim() || 'My Site';
    const siteDesc = siteDescInput?.value.trim() || '';
    const repoName = repoNameInput?.value.trim() || 'my-site';

    if (!repoName) return;

    goToStep(3);

    const apiHeaders = {
      Authorization: `token ${githubToken}`,
      Accept: 'application/vnd.github.v3+json',
      'Content-Type': 'application/json',
    };

    try {
      // Step 3a: Create repository from template
      updateCreatingStep('repo', 'active', 'Creating repository...', 10);

      if (!selectedTemplate) throw new Error('No template selected.');

      const [templateOwner, templateRepo] = selectedTemplate.repo.split('/');

      const createRes = await fetch(
        `https://api.github.com/repos/${templateOwner}/${templateRepo}/generate`,
        {
          method: 'POST',
          headers: {
            ...apiHeaders,
            Accept: 'application/vnd.github.baptiste-preview+json',
          },
          body: JSON.stringify({
            owner: githubUsername,
            name: repoName,
            description: siteDesc,
            private: false,
            include_all_branches: false,
          }),
        }
      );

      if (!createRes.ok) {
        const errData = await createRes.json().catch(() => ({}));
        if (createRes.status === 422 && errData.message?.includes('already exists')) {
          throw new Error(`A repository named "${repoName}" already exists in your account. Please go back and choose a different name.`);
        }
        if (createRes.status === 404) {
          throw new Error(`Template repository not found. The template "${selectedTemplate.repo}" may not be set up as a template yet.`);
        }
        throw new Error(errData.message || `Failed to create repository (${createRes.status}).`);
      }

      updateCreatingStep('repo', 'completed', 'Repository created!', 25);

      // Brief pause for GitHub to process
      await sleep(2000);

      // Step 3b: Template files are already copied by the generate API
      updateCreatingStep('template', 'active', 'Template files copied...', 40);
      await sleep(1500);
      updateCreatingStep('template', 'completed', 'Template files ready!', 50);

      // Step 3c: Update site configuration
      updateCreatingStep('config', 'active', 'Updating site configuration...', 55);

      const isUserSiteEarly = repoName.toLowerCase() === `${githubUsername.toLowerCase()}.github.io`;
      const siteUrl = isUserSiteEarly
        ? `https://${githubUsername}.github.io`
        : `https://${githubUsername}.github.io/${repoName}`;

      // Update site.config.json in the new repo
      // Structure: config.site.title, config.site.url, config.site.basePath, etc.
      //
      // Detect if this is a user/org site (repo name = username.github.io)
      // In that case, basePath is empty and URL includes no subpath
      const isUserSite = repoName.toLowerCase() === `${githubUsername.toLowerCase()}.github.io`;

      try {
        await updateRepoFile(
          apiHeaders,
          repoName,
          'site.config.json',
          (content: string) => {
            try {
              const config = JSON.parse(content);
              if (!config.site) config.site = {};
              config.site.title = siteName;
              config.site.description = siteDesc;
              config.site.url = `https://${githubUsername}.github.io`;
              config.site.basePath = isUserSite ? '' : `/${repoName}/`;
              // Update SEO title template to use the actual site name
              if (!config.seo) config.seo = {};
              config.seo.titleTemplate = `%s — ${siteName}`;
              // Set the author name from GitHub profile if available
              if (config.site.author && !config.site.author.name) {
                config.site.author.name = githubUsername;
              }
              return JSON.stringify(config, null, 2) + '\n';
            } catch {
              return content;
            }
          }
        );
      } catch {
        // File might not exist in all templates, that is OK
      }

      // No need to update astro.config.mjs — it reads from site.config.json
      // The basePath and site URL are picked up automatically

      updateCreatingStep('config', 'completed', 'Configuration updated!', 70);

      // Step 3d: Enable GitHub Pages
      updateCreatingStep('pages', 'active', 'Enabling GitHub Pages...', 75);

      // Try to enable GitHub Pages via the API
      // First, wait for the default branch to be available
      await sleep(2000);

      try {
        // Enable Pages with GitHub Actions as source
        const pagesRes = await fetch(
          `https://api.github.com/repos/${githubUsername}/${repoName}/pages`,
          {
            method: 'POST',
            headers: apiHeaders,
            body: JSON.stringify({
              build_type: 'workflow',
            }),
          }
        );

        if (!pagesRes.ok && pagesRes.status !== 409) {
          // 409 means Pages is already enabled
          // Try legacy source-based approach
          const pagesRes2 = await fetch(
            `https://api.github.com/repos/${githubUsername}/${repoName}/pages`,
            {
              method: 'POST',
              headers: apiHeaders,
              body: JSON.stringify({
                source: { branch: 'main', path: '/' },
              }),
            }
          );
          if (!pagesRes2.ok && pagesRes2.status !== 409) {
            console.warn('Could not enable Pages automatically. User may need to enable it manually.');
          }
        }
      } catch {
        console.warn('Pages API call failed, may need manual enablement.');
      }

      updateCreatingStep('pages', 'completed', 'GitHub Pages enabled!', 85);

      // Step 3e: Poll for deployment
      updateCreatingStep('deploy', 'active', 'Deploying your site...', 90);

      // Wait and poll for deployment
      let deployed = false;
      for (let i = 0; i < 30; i++) {
        await sleep(3000);

        try {
          const deployRes = await fetch(
            `https://api.github.com/repos/${githubUsername}/${repoName}/pages`,
            { headers: apiHeaders }
          );

          if (deployRes.ok) {
            const deployData = await deployRes.json();
            if (deployData.status === 'built') {
              deployed = true;
              break;
            }
          }
        } catch {
          // Continue polling
        }

        // Update progress incrementally
        const progressPct = Math.min(90 + i * 0.3, 98);
        creatingProgress.style.width = `${progressPct}%`;
      }

      updateCreatingStep('deploy', 'completed', 'Site deployed!', 100);

      // Proceed to success regardless (deployment might still be in progress)
      await sleep(500);
      showSuccess(siteUrl, repoName);
    } catch (err: any) {
      showCreatingError(err.message || 'An unexpected error occurred. Please try again.');
    }
  }

  async function updateRepoFile(
    headers: Record<string, string>,
    repoName: string,
    filePath: string,
    transform: (content: string) => string
  ) {
    // Get current file
    const getRes = await fetch(
      `https://api.github.com/repos/${githubUsername}/${repoName}/contents/${filePath}`,
      { headers }
    );

    if (!getRes.ok) throw new Error(`File ${filePath} not found.`);

    const fileData = await getRes.json();
    // Decode base64 content (UTF-8 safe)
    const rawContent = fileData.content.replace(/\n/g, '');
    const currentContent = decodeURIComponent(escape(atob(rawContent)));
    const newContent = transform(currentContent);

    if (newContent === currentContent) return;

    // Update file
    const updateRes = await fetch(
      `https://api.github.com/repos/${githubUsername}/${repoName}/contents/${filePath}`,
      {
        method: 'PUT',
        headers,
        body: JSON.stringify({
          message: `Configure site settings via Jinpa`,
          content: btoa(unescape(encodeURIComponent(newContent))),
          sha: fileData.sha,
        }),
      }
    );

    if (!updateRes.ok) {
      throw new Error(`Failed to update ${filePath}.`);
    }
  }

  function updateCreatingStep(
    stepName: string,
    status: 'active' | 'completed',
    statusText: string,
    progress: number
  ) {
    // Update the step item
    const stepEl = document.querySelector(`[data-creating-step="${stepName}"]`) as HTMLElement;
    if (stepEl) {
      stepEl.classList.remove('active', 'completed');
      stepEl.classList.add(status);

      const spinner = stepEl.querySelector('.creating-step-spinner') as HTMLElement;
      const check = stepEl.querySelector('.creating-step-check') as HTMLElement;

      if (status === 'active') {
        if (spinner) spinner.style.display = '';
        if (check) check.style.display = 'none';
      } else {
        if (spinner) spinner.style.display = 'none';
        if (check) check.style.display = '';
      }
    }

    // Update status text and progress bar
    if (creatingStatus) creatingStatus.textContent = statusText;
    if (creatingProgress) creatingProgress.style.width = `${progress}%`;
  }

  function showCreatingError(msg: string) {
    if (creatingError && creatingErrorMsg) {
      creatingError.hidden = false;
      creatingErrorMsg.textContent = msg;
    }
  }

  function showSuccess(siteUrl: string, repoName: string) {
    goToStep(4);
    createdRepoName = repoName;
    createdSiteUrl = siteUrl;

    const adminUrl = `${siteUrl}/admin/`;
    const fullRepo = `${githubUsername}/${repoName}`;

    if (successSiteUrl) {
      successSiteUrl.href = siteUrl;
      successSiteUrl.textContent = siteUrl;
    }

    if (visitSiteBtn) visitSiteBtn.href = siteUrl;
    if (adminPanelBtn) adminPanelBtn.href = adminUrl;

    // Pre-fill the admin token with the OAuth token (user doesn't need to enter it)
    if (adminTokenInput) adminTokenInput.value = githubToken;

    // Show admin setup section, hide action buttons until setup or skip
    if (adminSetupSection) adminSetupSection.hidden = false;
    if (successActions) successActions.hidden = true;
  }

  // --- Admin Setup: Encrypt token and hand off to admin panel ---

  // AES-256-GCM encryption (same as admin panel's Crypto module)
  const SALT_LEN = 16;
  const IV_LEN = 12;
  const PBKDF2_ITERATIONS = 600000;

  async function deriveKey(password: string, salt: BufferSource): Promise<CryptoKey> {
    const keyMaterial = await crypto.subtle.importKey(
      'raw',
      new TextEncoder().encode(password),
      'PBKDF2',
      false,
      ['deriveKey']
    );
    return crypto.subtle.deriveKey(
      { name: 'PBKDF2', salt, iterations: PBKDF2_ITERATIONS, hash: 'SHA-256' },
      keyMaterial,
      { name: 'AES-GCM', length: 256 },
      false,
      ['encrypt', 'decrypt']
    );
  }

  async function encryptToken(plaintext: string, password: string): Promise<string> {
    const salt = crypto.getRandomValues(new Uint8Array(SALT_LEN));
    const iv = crypto.getRandomValues(new Uint8Array(IV_LEN));
    const encoded = new TextEncoder().encode(plaintext);
    const key = await deriveKey(password, salt);
    const cipherBuf = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, key, encoded);
    const cipher = new Uint8Array(cipherBuf);
    const combined = new Uint8Array(salt.length + iv.length + cipher.length);
    combined.set(salt, 0);
    combined.set(iv, salt.length);
    combined.set(cipher, salt.length + iv.length);
    let binary = '';
    for (let i = 0; i < combined.length; i++) binary += String.fromCharCode(combined[i]);
    return btoa(binary);
  }

  setupAdminBtn?.addEventListener('click', async () => {
    const token = adminTokenInput?.value.trim();
    const pw1 = adminPw1?.value;
    const pw2 = adminPw2?.value;

    // Validate
    if (!token) { showAdminError('GitHub token missing. Please go back and log in again.'); return; }
    if (!pw1) { showAdminError('Please choose a password.'); return; }
    if (pw1.length < 4) { showAdminError('Password must be at least 4 characters.'); return; }
    if (pw1 !== pw2) { showAdminError('Passwords do not match.'); return; }

    setupAdminBtn.disabled = true;
    setupAdminBtn.textContent = 'Setting up...';
    hideAdminError();

    try {
      // Validate the token works
      const res = await fetch('https://api.github.com/user', {
        headers: { Authorization: `token ${token}`, Accept: 'application/vnd.github.v3+json' },
      });
      if (!res.ok) throw new Error('Token is invalid or expired. Please check and try again.');

      // Verify it has access to the repo
      const fullRepo = `${githubUsername}/${createdRepoName}`;
      const repoRes = await fetch(`https://api.github.com/repos/${fullRepo}`, {
        headers: { Authorization: `token ${token}`, Accept: 'application/vnd.github.v3+json' },
      });
      if (!repoRes.ok) throw new Error(`Could not access ${fullRepo}. Please try logging in again.`);

      // Encrypt the token
      const encrypted = await encryptToken(token, pw1);

      // Build the vault object (same format as admin panel's Auth.setup)
      const vault = {
        encrypted,
        repo: fullRepo,
        branch: 'main',
      };

      // Encode vault as URL-safe base64 for hash transfer
      const vaultB64 = btoa(JSON.stringify(vault));

      // Open admin panel with vault in URL hash
      // The hash is NEVER sent to the server — it stays client-side only
      const adminUrl = `${createdSiteUrl}/admin/#/import-vault/${encodeURIComponent(vaultB64)}`;

      // Clear sensitive fields
      if (adminTokenInput) adminTokenInput.value = '';
      if (adminPw1) adminPw1.value = '';
      if (adminPw2) adminPw2.value = '';

      // Show success state
      adminSetupSection.innerHTML = `
        <div class="admin-setup-success">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" fill="var(--color-success)" opacity="0.15"/><circle cx="12" cy="12" r="10" stroke="var(--color-success)" stroke-width="1.5"/><polyline points="8 12 11 15 16 9" stroke="var(--color-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <p>Admin access is encrypted and ready. Click below to open your admin panel.</p>
          <a href="${adminUrl}" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
            Open Admin Panel (Pre-Configured)
          </a>
        </div>
      `;

      // Also update the regular admin button to include the vault
      if (adminPanelBtn) adminPanelBtn.href = adminUrl;
      if (successActions) successActions.hidden = false;
    } catch (err: any) {
      showAdminError(err.message || 'Failed to set up admin access.');
      setupAdminBtn.disabled = false;
      setupAdminBtn.innerHTML = `<svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg> Set Up Admin & Open Panel`;
    }
  });

  skipAdminBtn?.addEventListener('click', () => {
    if (adminSetupSection) adminSetupSection.hidden = true;
    if (successActions) successActions.hidden = false;
  });

  function showAdminError(msg: string) {
    if (adminSetupError && adminSetupErrorMsg) {
      adminSetupError.hidden = false;
      adminSetupErrorMsg.textContent = msg;
    }
  }

  function hideAdminError() {
    if (adminSetupError) adminSetupError.hidden = true;
  }

  function sleep(ms: number): Promise<void> {
    return new Promise(resolve => setTimeout(resolve, ms));
  }
</script>
