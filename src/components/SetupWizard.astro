---
---

<div class="wizard-container">
  <!-- Step Indicators -->
  <div class="steps" id="wizard-steps">
    <div class="step active" data-step="1">
      <div class="step-number">1</div>
      <span class="step-label">Connect</span>
    </div>
    <div class="step-connector" data-connector="1"></div>
    <div class="step" data-step="2">
      <div class="step-number">2</div>
      <span class="step-label">Configure</span>
    </div>
    <div class="step-connector" data-connector="2"></div>
    <div class="step" data-step="3">
      <div class="step-number">3</div>
      <span class="step-label">Creating</span>
    </div>
    <div class="step-connector" data-connector="3"></div>
    <div class="step" data-step="4">
      <div class="step-number">4</div>
      <span class="step-label">Live!</span>
    </div>
  </div>

  <!-- Step 1: Connect GitHub -->
  <div class="wizard-step" id="step-1">
    <div class="wizard-step-content">
      <div class="wizard-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </div>
      <h2 class="wizard-title">Connect Your GitHub Account</h2>
      <p class="wizard-description">
        Jinpa uses GitHub to create and host your website. Your site will live in your GitHub account — you own it completely.
      </p>

      <div class="auth-section">
        <button class="btn btn-primary btn-lg" id="connect-github-btn" style="width: 100%;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          Login with GitHub
        </button>
        <p style="font-size: var(--text-sm); color: var(--text-tertiary); margin-top: var(--space-md); text-align: center;">
          You will be redirected to GitHub to authorize Jinpa. No passwords or tokens needed.
        </p>

        <div id="auth-error" class="alert alert-error" hidden>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="15" y1="9" x2="9" y2="15"/>
            <line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
          <span id="auth-error-message"></span>
        </div>

        <div id="auth-success" class="alert alert-success" hidden>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>Connected as <strong id="github-username"></strong></span>
        </div>
      </div>

      <div class="wizard-help">
        <details>
          <summary>New to GitHub?</summary>
          <div class="wizard-help-content">
            <p>GitHub is a free platform for hosting websites. Here is how to get started:</p>
            <ol>
              <li>Go to <a href="https://github.com/signup" target="_blank" rel="noopener noreferrer">github.com/signup</a> and create a free account</li>
              <li>Come back here and click <strong>Login with GitHub</strong></li>
              <li>Authorize Jinpa — that is it!</li>
            </ol>
          </div>
        </details>
      </div>
    </div>
  </div>

  <!-- Step 2: Configure Site -->
  <div class="wizard-step" id="step-2" hidden>
    <div class="wizard-step-content">
      <div class="wizard-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </div>
      <h2 class="wizard-title">Configure Your Site</h2>
      <p class="wizard-description">
        Choose a name and description for your new website.
      </p>

      <div class="template-selected" id="selected-template-info">
        <span class="template-selected-label">Template:</span>
        <span class="template-selected-name" id="selected-template-name">Starter Blog</span>
      </div>

      <form id="config-form" class="config-form">
        <div class="form-group">
          <label class="form-label" for="site-name">Site Name</label>
          <input
            type="text"
            id="site-name"
            class="form-input"
            placeholder="My Awesome Blog"
            required
            maxlength="100"
          />
          <p class="form-hint">This will be the title of your website.</p>
        </div>

        <div class="form-group">
          <label class="form-label" for="site-description">Description</label>
          <input
            type="text"
            id="site-description"
            class="form-input"
            placeholder="A blog about things I love"
            maxlength="200"
          />
          <p class="form-hint">A short description for search engines and social sharing.</p>
        </div>

        <div class="form-group">
          <label class="form-label" for="repo-name">Repository Name</label>
          <input
            type="text"
            id="repo-name"
            class="form-input"
            placeholder="my-awesome-blog"
            required
            pattern="[a-zA-Z0-9._-]+"
          />
          <p class="form-hint" id="repo-url-preview">
            Your site will be at: <strong><span id="preview-username">username</span>.github.io/<span id="preview-repo">repo-name</span></strong>
          </p>
        </div>

        <div class="domain-note">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="16" x2="12" y2="12"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
          <span>You can add a custom domain later through GitHub repository settings.</span>
        </div>

        <div class="wizard-actions">
          <button type="button" class="btn btn-secondary" id="back-to-step-1">Back</button>
          <button type="submit" class="btn btn-primary" id="create-site-btn">
            Create My Site
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Step 3: Creating -->
  <div class="wizard-step" id="step-3" hidden>
    <div class="wizard-step-content creating-content">
      <div class="creating-animation">
        <div class="creating-spinner">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="creating-rocket" aria-hidden="true">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
            <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
            <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
            <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
          </svg>
        </div>
      </div>

      <h2 class="wizard-title">Creating Your Website</h2>
      <p class="wizard-description" id="creating-status">Starting up...</p>

      <div class="progress-bar" style="margin: var(--space-xl) 0;">
        <div class="progress-bar-fill" id="creating-progress" style="width: 0%"></div>
      </div>

      <div class="creating-steps" id="creating-steps">
        <div class="creating-step" data-creating-step="repo">
          <div class="creating-step-indicator">
            <div class="spinner creating-step-spinner"></div>
            <svg class="creating-step-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display: none;">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span class="creating-step-text">Creating repository</span>
        </div>
        <div class="creating-step" data-creating-step="template">
          <div class="creating-step-indicator">
            <div class="spinner creating-step-spinner" style="display: none;"></div>
            <svg class="creating-step-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display: none;">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span class="creating-step-text">Copying template files</span>
        </div>
        <div class="creating-step" data-creating-step="config">
          <div class="creating-step-indicator">
            <div class="spinner creating-step-spinner" style="display: none;"></div>
            <svg class="creating-step-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display: none;">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span class="creating-step-text">Updating site configuration</span>
        </div>
        <div class="creating-step" data-creating-step="pages">
          <div class="creating-step-indicator">
            <div class="spinner creating-step-spinner" style="display: none;"></div>
            <svg class="creating-step-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display: none;">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span class="creating-step-text">Enabling GitHub Pages</span>
        </div>
        <div class="creating-step" data-creating-step="deploy">
          <div class="creating-step-indicator">
            <div class="spinner creating-step-spinner" style="display: none;"></div>
            <svg class="creating-step-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display: none;">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span class="creating-step-text">Deploying your site</span>
        </div>
      </div>

      <div id="creating-error" class="alert alert-error" hidden>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="15" y1="9" x2="9" y2="15"/>
          <line x1="9" y1="9" x2="15" y2="15"/>
        </svg>
        <span id="creating-error-message"></span>
      </div>
    </div>
  </div>

  <!-- Step 4: Success + Admin Setup -->
  <div class="wizard-step" id="step-4" hidden>
    <div class="wizard-step-content success-content">
      <div class="success-icon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="10" fill="var(--color-success)" opacity="0.15"/>
          <circle cx="12" cy="12" r="10" stroke="var(--color-success)" stroke-width="1.5"/>
          <polyline points="8 12 11 15 16 9" stroke="var(--color-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="success-checkmark"/>
        </svg>
      </div>

      <h2 class="wizard-title">Your Site is Live!</h2>
      <p class="wizard-description" id="success-message">
        Congratulations! Your website has been created and is now live on the web.
      </p>

      <div class="success-url" id="success-url-box">
        <div class="success-url-label">Your site is live at:</div>
        <a href="#" id="success-site-url" class="success-url-link" target="_blank" rel="noopener noreferrer">
          https://username.github.io/repo
        </a>
      </div>

      <div class="success-note" id="success-deploy-note">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="16" x2="12" y2="12"/>
          <line x1="12" y1="8" x2="12.01" y2="8"/>
        </svg>
        <span>It may take 1-2 minutes for your site to appear while GitHub builds it for the first time.</span>
      </div>

      <!-- Admin Setup Section — set up admin access right here -->
      <div class="admin-setup-section" id="admin-setup-section">
        <h3 class="admin-setup-title">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
          Set Up Admin Access
        </h3>
        <p class="admin-setup-desc">
          Your GitHub account is already connected. Just choose a password to protect your admin panel — you will use this every time you log in.
        </p>

        <!-- Hidden — pre-filled from OAuth token, not shown to user -->
        <input type="hidden" id="admin-token" />
        <span id="admin-repo-name-display" hidden></span>
        <a href="#" id="create-admin-token-link" hidden></a>

        <div class="form-group">
          <label class="form-label" for="admin-password">Choose a Password</label>
          <input type="password" id="admin-password" class="form-input" placeholder="You will use this to log in" autocomplete="new-password" />
          <p class="form-hint">This password encrypts your token. It never leaves your browser.</p>
        </div>

        <div class="form-group">
          <label class="form-label" for="admin-password2">Confirm Password</label>
          <input type="password" id="admin-password2" class="form-input" placeholder="Type it again" autocomplete="new-password" />
        </div>

        <div id="admin-setup-error" class="alert alert-error" hidden>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="15" y1="9" x2="9" y2="15"/>
            <line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
          <span id="admin-setup-error-msg"></span>
        </div>

        <button class="btn btn-primary" id="setup-admin-btn" style="width:100%;">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
          </svg>
          Set Up Admin &amp; Open Panel
        </button>

        <button class="btn btn-ghost btn-sm" id="skip-admin-setup" style="width:100%; margin-top: var(--space-sm);">
          Skip — I will set this up later in the admin panel
        </button>
      </div>

      <!-- Actions shown after admin setup or skip -->
      <div class="success-actions" id="success-actions" hidden>
        <a href="#" id="visit-site-btn" class="btn btn-primary btn-lg" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          Visit Your Site
        </a>
        <a href="#" id="admin-panel-btn" class="btn btn-secondary btn-lg" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
          Open Admin Panel
        </a>
      </div>

      <div class="success-extras">
        <h3>What is next?</h3>
        <ul class="success-next-steps">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Edit your content through the admin panel — no code needed
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Add a custom domain in your GitHub repository settings
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Explore your repository at GitHub to customize further
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>

<style>
  .wizard-container {
    max-width: 640px;
    margin: 0 auto;
  }

  .wizard-step-content {
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-2xl);
    padding: var(--space-3xl);
    text-align: center;
    animation: fadeInUp 0.4s ease;
  }

  .wizard-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 5rem;
    height: 5rem;
    border-radius: var(--border-radius-2xl);
    background: var(--bg-surface-raised);
    color: var(--text-primary);
    margin-bottom: var(--space-xl);
  }

  .wizard-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .wizard-description {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-bottom: var(--space-2xl);
    line-height: var(--leading-relaxed);
  }

  /* Auth Section */
  .auth-section {
    text-align: left;
    margin-bottom: var(--space-xl);
  }

  .auth-method {
    margin-bottom: var(--space-lg);
  }

  .auth-method-title {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .auth-method-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
    line-height: var(--leading-relaxed);
  }

  .auth-method-description a {
    font-weight: 500;
  }

  /* Ensure hidden attribute always hides elements even when CSS sets display */
