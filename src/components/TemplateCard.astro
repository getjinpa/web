---
interface Props {
  name: string;
  slug: string;
  description: string;
  thumbnail?: string;
  preview?: string;
  category: string;
  features: string[];
  comingSoon?: boolean;
}

const {
  name,
  slug,
  description,
  thumbnail,
  preview = '#',
  category,
  features,
  comingSoon = false,
} = Astro.props;

const featureLabels: Record<string, string> = {
  darkMode: 'Dark Mode',
  search: 'Search',
  rss: 'RSS',
  markdown: 'Markdown',
  gallery: 'Gallery',
  animations: 'Animations',
  responsive: 'Responsive',
  contactForm: 'Contact Form',
  testimonials: 'Testimonials',
  seo: 'SEO',
  sidebar: 'Sidebar',
  codeHighlight: 'Code Highlight',
  events: 'Events Calendar',
  calendar: 'Schedule',
  multilingual: 'Multilingual',
  donations: 'Donations',
  audio: 'Audio Player',
  tibetan: 'Tibetan Script',
  map: 'Location Map',
  teachings: 'Teachings Archive',
  bio: 'Biography',
  schedule: 'Teaching Schedule',
  gallery360: '360° Gallery',
  archive: 'Archive',
  portfolio: 'Portfolio',
};

const categoryLabels: Record<string, string> = {
  blog: 'Blog',
  'dharma-center': 'Dharma Center',
  teacher: 'Lama / Teacher',
  monastery: 'Monastery',
  artist: 'Artist / Creator',
  writer: 'Writer / Scholar',
  organization: 'Organization',
};

// Rich gradient backgrounds per category
const categoryGradients: Record<string, [string, string]> = {
  blog:            ['#1a1f3c', '#2e3a7a'],
  'dharma-center': ['#5c1f00', '#b84a00'],
  teacher:         ['#1a1200', '#6b4a00'],
  monastery:       ['#0f1e30', '#1a4060'],
  artist:          ['#280050', '#6b0fcf'],
  writer:          ['#0a2115', '#145c30'],
  organization:    ['#00303d', '#006080'],
};

const [g1, g2] = categoryGradients[category] ?? categoryGradients.blog;
const gradientStyle = `background: linear-gradient(135deg, ${g1} 0%, ${g2} 100%);`;

// Category SVG icon HTML (rendered into a 24×24 viewBox, stroke-based)
const categoryIcons: Record<string, string> = {
  blog: `
    <rect x="3" y="4" width="18" height="16" rx="2"/>
    <line x1="7" y1="9" x2="17" y2="9"/>
    <line x1="7" y1="13" x2="14" y2="13"/>
    <line x1="7" y1="17" x2="11" y2="17"/>`,

  'dharma-center': `
    <circle cx="12" cy="12" r="9"/>
    <circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"/>
    <line x1="12" y1="3" x2="12" y2="10"/>
    <line x1="12" y1="14" x2="12" y2="21"/>
    <line x1="3" y1="12" x2="10" y2="12"/>
    <line x1="14" y1="12" x2="21" y2="12"/>
    <line x1="5.6" y1="5.6" x2="9.8" y2="9.8"/>
    <line x1="14.2" y1="14.2" x2="18.4" y2="18.4"/>
    <line x1="18.4" y1="5.6" x2="14.2" y2="9.8"/>
    <line x1="9.8" y1="14.2" x2="5.6" y2="18.4"/>`,

  teacher: `
    <path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/>
    <circle cx="10" cy="7" r="4"/>
    <path d="M21 21v-2a4 4 0 0 0-3-3.87"/>
    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,

  monastery: `
    <path d="M12 2L8.5 7H4v2h16V7h-4.5Z"/>
    <rect x="4" y="9" width="16" height="2"/>
    <rect x="2" y="11" width="20" height="2"/>
    <rect x="2" y="13" width="20" height="8" rx="1"/>
    <rect x="9.5" y="16" width="5" height="5"/>`,

  artist: `
    <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.93 0 1.65-.75 1.65-1.69 0-.44-.18-.84-.46-1.13C11.5 17.67 11 16.93 11 16c0-1.66 1.34-3 3-3h1.06C17.72 13 20 10.87 20 8.25 20 4.79 16.42 2 12 2z"/>
    <circle cx="7" cy="10" r="1.5" fill="currentColor" stroke="none"/>
    <circle cx="12" cy="5.5" r="1.5" fill="currentColor" stroke="none"/>
    <circle cx="17" cy="10" r="1.5" fill="currentColor" stroke="none"/>`,

  writer: `
    <path d="M12 20h9"/>
    <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>`,

  organization: `
    <circle cx="12" cy="5" r="3"/>
    <circle cx="4" cy="19" r="3"/>
    <circle cx="20" cy="19" r="3"/>
    <path d="M12 8v4.5"/>
    <path d="M12 12.5l-5 4"/>
    <path d="M12 12.5l5 4"/>`,
};

const iconHtml = categoryIcons[category] ?? categoryIcons.blog;
const categoryLabel = categoryLabels[category] ?? category;
---

<article class:list={['template-card', 'card', { 'is-coming-soon': comingSoon }]} data-category={category}>
  <!-- Thumbnail -->
  <div class="template-thumbnail">
    {thumbnail ? (
      <img
        src={thumbnail}
        alt={`${name} template preview`}
        class="template-thumb-screenshot"
        width={640}
        height={400}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="template-thumb-bg" style={gradientStyle}>
        <div class="template-thumb-icon">
          <svg
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <Fragment set:html={iconHtml} />
          </svg>
        </div>
        <div class="template-thumb-name">{name}</div>
      </div>
    )}

    {!comingSoon && preview !== '#' && (
      <div class="template-thumbnail-overlay">
        <a href={preview} class="btn btn-sm btn-secondary" target="_blank" rel="noopener noreferrer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
          Live Preview
        </a>
      </div>
    )}

    {comingSoon && (
      <div class="coming-soon-badge" aria-label="Coming soon">Coming Soon</div>
    )}
  </div>

  <!-- Info -->
  <div class="template-info">
    <div class="template-meta">
      <span class="badge">{categoryLabel}</span>
    </div>
    <h3 class="template-name">{name}</h3>
    <p class="template-description">{description}</p>

    <div class="template-features">
      {features.slice(0, 4).map(f => (
        <span class="template-feature-tag">{featureLabels[f] || f}</span>
      ))}
    </div>

    <div class="template-actions">
      {comingSoon ? (
        <div class="coming-soon-action">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          In development
        </div>
      ) : (
        <>
          <a href={`/setup?template=${slug}`} class="btn btn-primary btn-sm template-use-btn">
            Use This Template
          </a>
          {preview !== '#' && (
            <a href={preview} class="btn btn-ghost btn-sm" target="_blank" rel="noopener noreferrer">
              Preview
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3.5 1.5H10.5V8.5"/>
                <path d="M10.5 1.5L1.5 10.5"/>
              </svg>
            </a>
          )}
        </>
      )}
    </div>
  </div>
</article>

<style>
  .template-card {
    display: flex;
    flex-direction: column;
  }

  /* ── Thumbnail ── */
  .template-thumbnail {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .template-thumb-bg {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .template-thumb-icon {
    color: rgba(255, 255, 255, 0.75);
    transition: transform var(--transition-base);
  }

  .template-thumb-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.02em;
  }

  .template-card:hover .template-thumb-icon {
    transform: translateY(-3px);
  }

  /* Screenshot thumbnail — anchored to the top so header + hero is always shown */
  .template-thumb-screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.4s ease;
  }

  .template-card:hover .template-thumb-screenshot {
    transform: scale(1.03);
  }

  /* ── Hover preview overlay ── */
  .template-thumbnail-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.55);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .template-card:hover .template-thumbnail-overlay {
    opacity: 1;
  }

  /* ── Coming Soon badge ── */
  .coming-soon-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    padding: 0.25rem 0.625rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--border-radius-full);
  }

  /* ── Card info ── */
  .template-info {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .template-meta {
    margin-bottom: var(--space-sm);
  }

  .template-name {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }

  .template-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-md);
    flex: 1;
  }

  .template-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: var(--space-lg);
  }

  .template-feature-tag {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-tertiary);
    background: var(--bg-surface-raised);
    border-radius: var(--border-radius-full);
    border: 1px solid var(--border-color-light);
  }

  /* ── Actions ── */
  .template-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border-color-light);
  }

  .template-use-btn {
    flex: 1;
  }

  .coming-soon-action {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    font-style: italic;
  }

  /* Subtle muted look for coming soon cards */
  .is-coming-soon .template-thumb-bg {
    filter: saturate(0.7);
  }
</style>
