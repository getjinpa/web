---
import BaseLayout from '../layouts/BaseLayout.astro';
import TemplateCard from '../components/TemplateCard.astro';

interface TemplateInfo {
  name: string;
  slug: string;
  repo: string;
  description: string;
  thumbnail?: string;
  preview?: string;
  category: string;
  features: string[];
  comingSoon?: boolean;
}

const templates: TemplateInfo[] = [
  // ── Available now ──────────────────────────────────────────────
  {
    name: 'Starter Blog',
    slug: 'starter-blog',
    repo: 'getjinpa/jinpa-starter',
    description: 'A clean, minimal blog with dark mode, search, and RSS. Perfect for writers, teachers, and creators who want a beautiful space to share their work.',
    thumbnail: '/thumbnails/starter-blog.jpg',
    preview: 'https://getjinpa.github.io/jinpa-starter/',
    category: 'blog',
    features: ['darkMode', 'search', 'rss', 'markdown'],
    comingSoon: false,
  },

  {
    name: 'Stillwater',
    slug: 'dharma-center',
    repo: 'getjinpa/dhc-stillwater',
    description: 'A dharma center built for the Hudson Valley — meditation courses, events, teacher pages, and a warm non-sectarian community feel.',
    thumbnail: '/thumbnails/stillwater.jpg',
    preview: 'https://getjinpa.github.io/dhc-stillwater/',
    category: 'dharma-center',
    features: ['events', 'programs', 'teachers', 'responsive'],
    comingSoon: false,
  },

  {
    name: 'Lantern',
    slug: 'teacher',
    repo: 'getjinpa/lantern',
    description: 'A dignified personal site for Buddhist teachers and lamas. Biographical pages, teaching archives, upcoming programs, and contact details.',
    thumbnail: '/thumbnails/lantern.jpg',
    preview: 'https://getjinpa.github.io/lantern/',
    category: 'teacher',
    features: ['bio', 'schedule', 'teachings', 'responsive'],
    comingSoon: false,
  },
  {
    name: 'Stone Gate',
    slug: 'monastery',
    repo: 'getjinpa/stone-gate',
    description: 'Built for monasteries and retreat centers. Share your history, daily schedule, resident teachings, and invite visitors with a serene minimal design.',
    thumbnail: '/thumbnails/stone-gate.jpg',
    preview: 'https://getjinpa.github.io/stone-gate/',
    category: 'monastery',
    features: ['gallery', 'schedule', 'responsive', 'seo'],
    comingSoon: false,
  },
  {
    name: 'Vermillion',
    slug: 'artist',
    repo: 'getjinpa/vermillion',
    description: 'Showcase your visual work — thangka, photography, illustration, sculpture. A portfolio template for Tibetan and Buddhist artists and cultural centers.',
    thumbnail: '/thumbnails/vermillion.jpg',
    preview: 'https://getjinpa.github.io/vermillion/',
    category: 'artist',
    features: ['gallery', 'portfolio', 'programs', 'responsive'],
    comingSoon: false,
  },
  {
    name: 'Inkwell',
    slug: 'writer',
    repo: 'getjinpa/inkwell',
    description: 'For authors, scholars, and publishers. Share books, essays, translations, and research in a clean, literary reading-focused layout.',
    thumbnail: '/thumbnails/inkwell.jpg',
    preview: 'https://getjinpa.github.io/inkwell/',
    category: 'writer',
    features: ['archive', 'search', 'rss', 'seo'],
    comingSoon: false,
  },
  {
    name: 'Pebble',
    slug: 'artist-minimal',
    repo: 'getjinpa/pebble',
    description: 'A minimal one-page artist site. Name, bio, a gallery of works, and social links — nothing more. Clean, warm, and elegant.',
    thumbnail: '/thumbnails/pebble.jpg',
    preview: 'https://getjinpa.github.io/pebble/',
    category: 'artist',
    features: ['onePage', 'gallery', 'minimal', 'responsive'],
    comingSoon: false,
  },
  {
    name: 'Common Ground',
    slug: 'organization',
    repo: 'getjinpa/common-ground',
    description: 'A warm, welcoming template for mindfulness centers, NGOs, and community groups. Programs, team pages, blog, and community-focused design.',
    thumbnail: '/thumbnails/common-ground.jpg',
    preview: 'https://getjinpa.github.io/common-ground/',
    category: 'organization',
    features: ['events', 'programs', 'contactForm', 'responsive'],
    comingSoon: false,
  },
];

const categories = [
  { slug: 'all',            label: 'All Templates' },
  { slug: 'blog',           label: 'Blog / Personal' },
  { slug: 'dharma-center',  label: 'Dharma Center' },
  { slug: 'teacher',        label: 'Lama / Teacher' },
  { slug: 'monastery',      label: 'Monastery' },
  { slug: 'artist',         label: 'Artist / Creator' },
  { slug: 'writer',         label: 'Writer / Scholar' },
  { slug: 'organization',   label: 'Organization' },
];
---

<BaseLayout
  title="Templates"
  description="Free website templates for Tibetan teachers, dharma centers, monasteries, artists, and writers. Launch your site in minutes."
  currentPage="templates"
>
  <section class="templates-hero">
    <div class="container">
      <p class="templates-eyebrow">Free &amp; open source</p>
      <h1 class="templates-title">Templates for Your Community</h1>
      <p class="templates-subtitle">
        Beautiful, ready-made sites for Tibetan teachers, dharma centers, monasteries,
        artists, and writers. Pick a template — your site is live in minutes.
      </p>
    </div>
  </section>

  <section class="templates-gallery section">
    <div class="container">
      <!-- Category Filter -->
      <div class="category-filter" id="category-filter" role="group" aria-label="Filter templates by category">
        {categories.map(cat => (
          <button
            class:list={['filter-btn', { active: cat.slug === 'all' }]}
            data-category={cat.slug}
            type="button"
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Template Grid -->
      <div class="templates-grid" id="templates-grid">
        {templates.map(template => (
          <TemplateCard
            name={template.name}
            slug={template.slug}
            description={template.description}
            thumbnail={template.thumbnail}
            preview={template.preview}
            category={template.category}
            features={template.features}
            comingSoon={template.comingSoon}
          />
        ))}
      </div>

      <!-- Empty State -->
      <div class="templates-empty" id="templates-empty" hidden>
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-tertiary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
        <p>No templates in this category yet — check back soon.</p>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="templates-cta section">
    <div class="container">
      <div class="cta-box">
        <div class="cta-text">
          <h2>Want a custom template?</h2>
          <p>We're building new templates for the community. If your organisation has specific needs, let us know — we'd love to hear from you.</p>
        </div>
        <a href="https://github.com/getjinpa/jinpa-starter/discussions" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
          Get in touch
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .templates-hero {
    padding: var(--space-4xl) 0 var(--space-2xl);
    text-align: center;
    background: var(--bg-surface-raised);
    border-bottom: 1px solid var(--border-color);
  }

  .templates-eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .templates-title {
    font-size: var(--text-5xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-md);
  }

  .templates-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 540px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* ── Filter ── */
  .category-filter {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.4375rem 1rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--border-radius-full);
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .filter-btn:hover {
    background: var(--bg-surface-raised);
    color: var(--text-primary);
    border-color: var(--border-color);
  }

  .filter-btn.active {
    background: var(--color-primary);
    color: #ffffff;
    border-color: var(--color-primary);
  }

  /* ── Grid ── */
  .templates-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-xl);
  }

  /* ── Empty state ── */
  .templates-empty {
    text-align: center;
    padding: var(--space-4xl) 0;
    color: var(--text-tertiary);
  }

  .templates-empty p {
    margin-top: var(--space-md);
    font-size: var(--text-base);
  }

  /* ── CTA ── */
  .templates-cta {
    background: var(--bg-surface-raised);
    border-top: 1px solid var(--border-color);
  }

  .cta-box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    padding: var(--space-2xl);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
  }

  .cta-text h2 {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }

  .cta-text p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    max-width: 480px;
    line-height: var(--leading-relaxed);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .templates-title {
      font-size: var(--text-3xl);
    }

    .templates-grid {
      grid-template-columns: 1fr;
    }

    .cta-box {
      flex-direction: column;
      text-align: center;
    }

    .cta-text p {
      max-width: none;
    }
  }
</style>

<script>
  // Category filtering
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const emptyState = document.getElementById('templates-empty');
  const cards = document.querySelectorAll<HTMLElement>('.template-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const category = btn.getAttribute('data-category');
      let visibleCount = 0;

      cards.forEach(card => {
        const cardCategory = card.getAttribute('data-category');
        const show = category === 'all' || cardCategory === category;
        card.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      if (emptyState) {
        emptyState.hidden = visibleCount > 0;
      }
    });
  });
</script>
